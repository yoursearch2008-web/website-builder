        { "id": "bl2", "type": "hero", "variant": "centered", "props": { "headline": "Blog", "subheadline": "Latest news and tips on website monetization.", "cta": "", "ctaLink": "" }},
        { "id": "bl3", "type": "content", "variant": "default", "props": { "content": "<h2>Getting Started with Self-Hosted Ads</h2><p>Learn how to set up your own ad server and start monetizing your website today.</p><a href='/blog/getting-started' class='btn'>Read More</a><hr><h2>Maximizing Your Revenue</h2><p>Tips and strategies for getting the most out of your ad placements.</p><a href='/blog/revenue-tips' class='btn'>Read More</a><hr><h2>The Future of Digital Advertising</h2><p>Why open-source advertising is the way forward.</p><a href='/blog/future-ads' class='btn'>Read More</a>" }},
