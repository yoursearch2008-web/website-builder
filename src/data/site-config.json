        { "id": "s2", "type": "hero", "variant": "centered", "props": { "headline": "Our Services", "subheadline": "Everything you need to monetize your website effectively.", "cta": "", "ctaLink": "" }},
        { "id": "s3", "type": "features", "variant": "grid", "props": { "title": "What We Do", "features": [{"title":"Ad Server Setup","desc":"We configure Revive AdServer for your domain with optimal settings","icon":"Settings"},{"title":"Campaign Management","desc":"Create and manage ad campaigns with our easy interface","icon":"Target"},{"title":"Analytics","desc":"Detailed stats on impressions, clicks, and revenue","icon":"Chart"},{"title":"Support","desc":"Help when you need it, how you need it","icon":"Help"}] }},
        { "id": "s4", "type": "content", "variant": "default", "props": { "content": "<h2>Who Is This For?</h2><p>Our services are perfect for:</p><ul><li>Website publishers with 1,000+ monthly visitors</li><li>Bloggers who want to monetize without AdSense</li><li>Small businesses with multiple websites</li><li>Content creators looking for alternative revenue</li></ul><h2>What's Included</h2><p>Every service package includes: full setup, training materials, and 30 days of support. After that, self-serve or upgrade for ongoing help.</p>" }},
