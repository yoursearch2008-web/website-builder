      "path": "/about",
      "blocks": [
        { "id": "a1", "type": "navbar", "variant": "default", "props": { "logo": "OpenServe", "links": [{"label":"Home","href":"/"},{"label":"About","href":"/about"},{"label":"Services","href":"/services"},{"label":"Pricing","href":"/pricing"},{"label":"Blog","href":"/blog"},{"label":"Contact","href":"/contact"}] }},
        { "id": "a2", "type": "hero", "variant": "centered", "props": { "headline": "About OpenServe", "subheadline": "We believe in free and open advertising for everyone.", "cta": "", "ctaLink": "" }},
        { "id": "a3", "type": "content", "variant": "default", "props": { "content": "<h2>Our Mission</h2><p>OpenServe exists to democratize online advertising. We believe every website publisher deserves a chance to monetize their content without giving up most of their revenue to tech giants.</p><h2>Who We Are</h2><p>We're a team of developers and marketers who have worked in online advertising for over 15 years. We've seen how traditional ad networks take 40-50% of publisher revenue. We decided to do something about it.</p><h2>What We Offer</h2><p>A complete self-hosted ad platform that puts you in control. No middleman, no fees, no contracts. Just you and your revenue.</p>" }},
        { "id": "a4", "type": "team", "variant": "grid", "props": { "title": "Our Team", "members": [{"name":"Sarah Chen","role":"CEO & Founder","bio":"15 years in ad tech"},{"name":"Mike Johnson","role":"CTO","bio":"Open source developer"},{"name":"Ana Garcia","role":"Head of Marketing","bio":"Growth specialist"},{"name":"James Lee","role":"Lead Developer","bio":"Full stack engineer"}] }},
