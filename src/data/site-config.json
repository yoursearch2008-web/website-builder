        { "id": "p4", "type": "faq", "variant": "accordion", "props": { "title": "Pricing FAQs", "items": [{"question":"Is it really free?","answer":"Yes. The Free plan is free forever. No credit card required."},{"question":"What does Pro include?","answer":"Pro includes priority support, advanced analytics, custom domains, and API access for $5/month."},{"question":"Can I cancel anytime?","answer":"Yes. Cancel anytime with no penalties or fees."},{"question":"Is there a trial?","answer":"The Free plan IS your trial. Use it as long as you want."}] }},
