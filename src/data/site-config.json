        { "id": "ca2", "type": "hero", "variant": "centered", "props": { "headline": "Join Our Team", "subheadline": "Help us revolutionize online advertising.", "cta": "", "ctaLink": "" }},
        { "id": "ca3", "type": "content", "variant": "default", "props": { "content": "<h2>Open Positions</h2><h3>Senior Developer</h3><p>We're looking for an experienced developer to help build the future of open advertising. Remote work available.</p><p><strong>Requirements:</strong> 5+ years experience, knowledge of PHP/MySQL, open source contributions a plus.</p><h3>Marketing Manager</h3><p>Help spread the word about open advertising. Remote work available.</p><p><strong>Requirements:</strong> 3+ years in digital marketing, content creation experience.</p>" }},
