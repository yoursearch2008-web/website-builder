        { "id": "c2", "type": "hero", "variant": "centered", "props": { "headline": "Contact Us", "subheadline": "We'd love to hear from you.", "cta": "", "ctaLink": "" }},
        { "id": "c3", "type": "contact", "variant": "default", "props": { "title": "Get In Touch", "email": "hello@openserve.com", "phone": "+1-555-123-4567", "address": "123 Main Street, San Francisco, CA 94105", "hours": "Mon-Fri 9am-5pm PST" }},
        { "id": "c4", "type": "content", "variant": "default", "props": { "content": "<h2>Frequently Asked Questions</h2><p><strong>How fast do you respond?</strong><br>We typically respond within 24 hours.</p><p><strong>Do you offer phone support?</strong><br>Yes, Pro and Enterprise plans include phone support.</p><p><strong>Can I schedule a demo?</strong><br>Absolutely! Contact us to schedule a personalized demo.</p>" }},
