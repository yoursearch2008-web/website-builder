        { "id": "f3", "type": "faq", "variant": "accordion", "props": { "title": "Common Questions", "items": [{"question":"What is OpenServe?","answer":"OpenServe is a free, open-source advertising platform that lets you monetize your website without sharing revenue with middlemen."},{"question":"Is it really free?","answer":"Yes! Our core features are completely free. No hidden fees, no surprises."},{"question":"How do I get started?","answer":"Simply sign up for an account and follow our easy setup guide. You'll be monetizing in minutes."},{"question":"How is this different from AdSense?","answer":"Unlike AdSense, you keep 100% of your revenue, there's no approval process, and you own your data."},{"question":"What websites work best?","answer":"Any website with regular traffic can benefit. Blogs, news sites, and content sites work especially well."},{"question":"Can I use this with other ad networks?","answer":"Yes! OpenServe works alongside other ad networks without conflict."}] }},
