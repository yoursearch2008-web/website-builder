        { "id": "ai3", "type": "content", "variant": "default", "props": { "content": "<div class='ai-container'><h2>Chat with AI</h2><p>Ask me anything about advertising, websites, or technology.</p><div class='chat-box'><input type='text' id='chat-input' placeholder='Type your message...' /><button onclick='sendChat()'>Send</button></div><div id='chat-response' class='response-box'></div><hr><h2>Research Tool</h2><p>Search the web and get AI-powered summaries.</p><div class='research-box'><input type='text' id='research-input' placeholder='What do you want to research?' /><button onclick='doResearch()'>Search</button></div><div id='research-results' class='results-box'></div></div>" }},
