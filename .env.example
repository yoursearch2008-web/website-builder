# AI Generation (Gemini)
# Required for the /api/generate endpoint
GEMINI_API_KEY=

# Image Search (Pexels)
# Required for the /api/pexels image search endpoint
PEXELS_API_KEY=

# One-Click Deploy (Vercel)
# Required for the /api/deploy endpoint
VERCEL_DEPLOY_TOKEN=
VERCEL_TEAM_ID=

# Deploy Security
# Secret key to authorize deploy requests
OPENPAGE_DEPLOY_KEY=
# Comma-separated list of allowed CORS origins
OPENPAGE_ALLOWED_ORIGINS=https://openpage-phi.vercel.app
