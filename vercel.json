{
  "functions": {
    "api/generate.ts": {
      "maxDuration": 60
    },
    "api/deploy.ts": {
      "maxDuration": 30
    },
    "api/chat.ts": {
      "maxDuration": 30
    },
    "api/research.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
